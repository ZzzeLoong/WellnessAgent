# =========================
# WellnessAgent demo config
# =========================

# ---- LLM (required) ----
# 使用任意 OpenAI 兼容接口都可以
LLM_MODEL_ID=
LLM_API_KEY=
LLM_BASE_URL= 
LLM_TIMEOUT=60

# ---- Embedding (required) ----
# 可选: local / dashscope / tfidf
# 若使用 local，可先尝试:
# EMBED_MODEL_TYPE=local
# EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_MODEL_TYPE=local
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_API_KEY=
EMBED_BASE_URL=

# ---- Qdrant (required) ----
# 本地示例: http://localhost:6333
# 注意：切换 EMBED_MODEL_TYPE / EMBED_MODEL_NAME 后，向量维度可能变化。
# WellnessAgent 会对 RAG 集合自动重建，但其他非派生集合请谨慎处理。
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hello_agents_vectors
QDRANT_DISTANCE=cosine

# ---- Demo behavior (optional) ----
WELLNESS_DEMO_USER_ID=wellness_demo_user
WELLNESS_RESET_DEMO_DATA=true

# ---- Distillation memory (optional) ----
# 默认会每 4 轮尝试把近期对话提纯为少量长期记忆
DISTILL_ENABLED=true
DISTILL_EVERY_N_TURNS=4
# 若留空，则回退使用主 LLM 做提纯
DISTILL_MODEL_ID=
DISTILL_API_KEY=
DISTILL_BASE_URL=

# ---- RAG advanced retrieval (optional) ----
RAG_SEARCH_ENABLE_MQE=true
RAG_SEARCH_ENABLE_HYDE=false
RAG_ANSWER_ENABLE_MQE=true
RAG_ANSWER_ENABLE_HYDE=true

# ---- Optional provider-specific keys ----
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# OLLAMA_HOST=http://localhost:11434/v1
